+    def scrape_live_events(self, region_filter=None, months=None,
+                           radius_km=None) -> List[Dict]:
+        """Scrape eTrainu across several months and accumulate the results.
+
+        The site shows one month of events at a time within a location radius
+        (default 10km). We widen the radius and step forward month-by-month,
+        de-duping as we go, so a month with no events doesn't end the scrape — it
+        just advances. Config knobs (under etrainu_config):
+            scrape_months      : how many months forward to walk (default 4)
+            location_radius_km : geo radius to request (default 50)
+        """
+        cfg = (self.config.get('etrainu_config', {}) or {}) if self.config else {}
+        if months is None:
+            months = int(cfg.get('scrape_months', 4) or 4)
+        if radius_km is None:
+            radius_km = int(cfg.get('location_radius_km', 50) or 50)
+        months = max(1, months)
+
+        logger.info(f"Scraping eTrainu: up to {months} month(s), radius {radius_km}km...")
+
+        # Widen the net before the first read.
+        self._set_location_radius(radius_km)
+
+        all_events: List[Dict] = []
+        seen = set()
+        for i in range(months):
+            view = self._scrape_current_view()
+            new = 0
+            for ev in view:
+                key = (ev.get('data_event_id') or ev.get('event_id')
+                       or (ev.get('title', '') + '|'
+                           + ((ev.get('sessions') or [{}])[0].get('date', '') if ev.get('sessions') else '')))
+                if key in seen:
+                    continue
+                seen.add(key)
+                all_events.append(ev)
+                new += 1
+            logger.info(f"Month {i + 1}/{months}: {len(view)} on page, {new} new; "
+                        f"running total {len(all_events)}")
+            if i < months - 1:
+                if not self._go_to_next_month():
+                    logger.info("No next-month control found — stopping after this month.")
+                    break
+
+        self.events = all_events
+        logger.info(f"Successfully scraped {len(all_events)} live events from ETrainU "
+                    f"across {min(months, i + 1)} month(s)")
+        if all_events:
+            event_types: Dict[str, int] = {}
+            for event in all_events:
+                event_types[event['course_type']] = event_types.get(event['course_type'], 0) + 1
+            logger.info("Event types found:")
+            for et, count in event_types.items():
+                logger.info(f"  - {et}: {count}")
+        return all_events
+
+    def _set_location_radius(self, km) -> bool:
+        """Set the geo radius <select id='geoRadiusSelect'> to `km` and let the
+        list refresh. Best-effort: if the control isn't present we leave the
+        default rather than failing the whole scrape."""
+        try:
+            from selenium.webdriver.support.ui import Select
+            time.sleep(1)
+            sel = self.driver.find_element(By.ID, 'geoRadiusSelect')
+            Select(sel).select_by_value(str(km))
+            # Fire a change event in case the SPA listens for it rather than onchange.
+            self.driver.execute_script(
+                "arguments[0].dispatchEvent(new Event('change', {bubbles:true}));", sel)
+            logger.info(f"Set eTrainu location radius to {km}km")
+            time.sleep(2)  # allow results to refresh
+            return True
+        except Exception as e:
+            logger.warning(f"Could not set radius to {km}km ({e}); keeping site default.")
+            return False
+
+    def _go_to_next_month(self) -> bool:
+        """Advance the list/calendar to the next month. Returns True if it clicked
+        a next-month control, False if none was found (caller then stops).
+
+        NOTE: candidate selectors below are best-effort — confirm against the live
+        DOM and prune to the one that works. They cover common material-icon and
+        FullCalendar patterns."""
+        candidates = [
+            (By.CSS_SELECTOR, "button[aria-label='Next'], button[aria-label='Next month']"),
+            (By.CSS_SELECTOR, ".fc-next-button"),
+            (By.XPATH, "//i[normalize-space()='chevron_right']/ancestor::button[1]"),
+            (By.XPATH, "//i[normalize-space()='navigate_next']/ancestor::*[self::button or self::a][1]"),
+            (By.XPATH, "//button[contains(@class,'next') and not(@disabled)]"),
+        ]
+        for by, sel in candidates:
+            try:
+                btn = self.driver.find_element(by, sel)
+                if not btn.is_enabled():
+                    continue
+                self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", btn)
+                time.sleep(0.3)
+                btn.click()
+                logger.info(f"Advanced to next month via: {sel}")
+                time.sleep(2)  # allow the month's events to load
+                return True
+            except Exception:
+                continue
+        return False
+
